# Supply-chain protection: refuse to install any package version published
# less than 7 days ago. Defeats short-lived malicious publishes (axios 2026,
# eslint-config-prettier, etc. — most were yanked within hours).
#
# Requires npm >= 11.10.0 (Feb 2026). Older npm silently ignores this line.
# Has no effect on `npm ci` (lockfile is authoritative); it gates `npm install`,
# `npm update`, and lockfile-update tooling.
min-release-age=7
